<h1>Edit Order</h1>

<form action="/orders/<%= order.order_id %>?_method=PUT" method="POST" class="form-grid">
  <label for="user_id">User</label>
  <select id="user_id" name="user_id" required>
    <% users.forEach(user => { %>
      <option value="<%= user.user_id %>" <%= String(order.user_id) === String(user.user_id) ? 'selected' : '' %>>
        <%= user.username %> (<%= user.email %>)
      </option>
    <% }) %>
  </select>

  <label for="order_date">Order Date</label>
  <input
    id="order_date"
    type="datetime-local"
    name="order_date"
    value="<%= new Date(order.order_date).toISOString().slice(0,16) %>"
  />

  <label for="status">Status</label>
  <select id="status" name="status" required>
    <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
    <option value="paid" <%= order.status === 'paid' ? 'selected' : '' %>>Paid</option>
    <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>Shipped</option>
    <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Completed</option>
    <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
  </select>

  <label for="total_price">Total Price</label>
  <input id="total_price" type="number" step="0.01" min="0" name="total_price" value="<%= order.total_price %>" required />

  <div class="form-actions">
    <a href="/orders" class="btn btn-cancel">Cancel</a>
    <button type="submit" class="btn btn-primary">Update</button>
  </div>
</form>
