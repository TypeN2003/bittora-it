<div class="page-title-row">
  <h1>Order Detail</h1>
  <a href="/orders" class="btn btn-secondary">Back</a>
</div>

<div class="card">
  <p><strong>ID:</strong> <%= order.order_id %></p>
  <p><strong>User:</strong> <%= order.User ? order.User.username : '-' %></p>
  <p><strong>Date:</strong> <%= new Date(order.order_date).toLocaleString() %></p>
  <p><strong>Status:</strong> <%= order.status %></p>
  <p><strong>Total:</strong> $<%= Number(order.total_price).toFixed(2) %></p>
</div>

<h2>Order Items</h2>
<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>Order Item ID</th>
        <th>Product</th>
        <th>Quantity</th>
        <th>Subtotal</th>
      </tr>
    </thead>
    <tbody>
      <% if (!order.OrderItems || !order.OrderItems.length) { %>
        <tr><td colspan="4">No order items in this order.</td></tr>
      <% } %>
      <% (order.OrderItems || []).forEach(item => { %>
        <tr>
          <td><%= item.order_item_id %></td>
          <td><%= item.Product ? item.Product.product_name : '-' %></td>
          <td><%= item.quantity %></td>
          <td>$<%= Number(item.subtotal).toFixed(2) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
