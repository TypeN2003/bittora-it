<header class="navbar">
  <div class="brand">Bittora IT Store</div>
  <nav class="nav-links">
    <% if (currentUser) { %>
      <% if (isAdmin) { %>
        <a href="/">Dashboard</a>
        <a href="/products">Products</a>
        <a href="/orders">Orders</a>
        <a href="/users">Users</a>
        <a href="/order_items">Order Items</a>
        <a href="/reports">Reports</a>
        <a href="/categories">Categories</a>
      <% } else { %>
        <a href="/">Home</a>
        <a href="/cart" class="cart-link" aria-label="Shopping cart">
          <span class="cart-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
              <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zm10 0c-1.1 0-1.99.9-1.99 2S15.9 22 17 22s2-.9 2-2-.9-2-2-2zM7.16 14h9.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1 1 0 0 0 21.06 5H5.21L4.27 3H1v2h2l3.6 7.59-1.35 2.44C4.52 16.37 5.48 18 7 18h12v-2H7l1.16-2z"/>
            </svg>
          </span>
          <span>Cart</span>
          <span class="cart-badge js-cart-count"><%= typeof cartCount !== 'undefined' ? cartCount : 0 %></span>
        </a>
        <a href="/orders/history">My Orders</a>
      <% } %>
    <% } else { %>
      <a href="/auth/login">Login</a>
    <% } %>
  </nav>
  <div class="nav-right">
    <% if (currentUser) { %>
      <span class="user-badge"><%= currentUser.username %> (<%= isAdmin ? 'admin' : 'user' %>)</span>
      <form method="POST" action="/auth/logout" class="inline-form">
        <button type="submit" class="btn btn-cancel">Logout</button>
      </form>
    <% } %>
    <button type="button" id="themeToggle" class="btn btn-secondary toggle-theme no-print">Dark Mode</button>
  </div>
</header>
