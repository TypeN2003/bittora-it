<h1>Categories</h1>

<form action="/categories" method="POST" class="form-grid">
  <label for="category_name">Category Name</label>
  <input id="category_name" type="text" name="category_name" required />
  <div class="form-actions">
    <button type="submit" class="btn btn-create">Add</button>
  </div>
</form>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!categories.length) { %>
        <tr><td colspan="3">No categories found.</td></tr>
      <% } %>
      <% categories.forEach(cat => { %>
        <tr>
          <td><%= cat.category_id %></td>
          <td><%= cat.category_name %></td>
          <td class="cart-actions">
            <a href="/categories/<%= cat.category_id %>/edit" class="btn btn-warning">Edit</a>
            <form action="/categories/<%= cat.category_id %>?_method=DELETE" method="POST" class="inline-form">
              <button type="submit" class="btn btn-delete" data-confirm-delete="Delete this category?">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
