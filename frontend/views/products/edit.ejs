<h1>Edit Product</h1>

<% if (errors && errors.length) { %>
  <div class="alert error">
    <ul class="error-list">
      <% errors.forEach(err => { %>
        <li><%= err.msg %></li>
      <% }) %>
    </ul>
  </div>
<% } %>

<form action="/products/<%= product.product_id %>/update" method="POST" enctype="multipart/form-data" class="form-grid">
  <label for="product_name">Product Name</label>
  <input id="product_name" type="text" name="product_name" value="<%= formData.product_name %>" required />

  <label for="price">Price</label>
  <input id="price" type="number" step="0.01" min="0" name="price" value="<%= formData.price %>" required />

  <label for="stock">Stock</label>
  <input id="stock" type="number" min="0" name="stock" value="<%= formData.stock %>" required />

  <label for="category_id">Category</label>
  <select id="category_id" name="category_id" required>
    <% categories.forEach(cat => { %>
      <option value="<%= cat.category_id %>" <%= String(formData.category_id) === String(cat.category_id) ? 'selected' : '' %>>
        <%= cat.category_name %>
      </option>
    <% }) %>
  </select>

  <label for="description">Description</label>
  <textarea id="description" name="description"><%= formData.description || '' %></textarea>

  <label for="image">Product Image</label>
  <input id="image" type="file" name="image" accept="image/*" />
  <% if (formData.image_url) { %>
    <img src="<%= formData.image_url %>?v=<%= Date.now() %>" alt="<%= formData.product_name %>" class="product-thumb" />
  <% } %>

  <div class="form-actions">
    <a href="/products" class="btn btn-cancel">Cancel</a>
    <button type="submit" class="btn btn-primary">Update</button>
  </div>
</form>
