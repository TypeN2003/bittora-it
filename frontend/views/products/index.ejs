<div class="page-title-row">
  <h1>Products</h1>
  <div class="actions">
    <% if (isAdmin) { %>
      <a href="/products/report" class="btn btn-secondary">Print Report</a>
      <a href="/products/new" class="btn btn-create">Add Product</a>
    <% } %>
  </div>
</div>

<form method="GET" action="/products" class="filter-row">
  <input
    type="text"
    name="search"
    placeholder="Search by product name or category"
    value="<%= searchQuery %>"
  />

  <select name="category">
    <option value="">All categories</option>
    <% categories.forEach(cat => { %>
      <option value="<%= cat.category_id %>" <%= String(selectedCategory) === String(cat.category_id) ? 'selected' : '' %>>
        <%= cat.category_name %>
      </option>
    <% }) %>
  </select>

  <button type="submit" class="btn btn-secondary">Filter</button>
</form>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Image</th>
        <th>Name</th>
        <th>Description</th>
        <th>Price</th>
        <th>Stock</th>
        <th>Category</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!products.length) { %>
        <tr>
          <td colspan="8">No products found.</td>
        </tr>
      <% } %>

      <% products.forEach(product => { %>
        <tr>
          <td><%= product.product_id %></td>
          <td>
            <% if (product.image_url) { %>
              <img src="<%= product.image_url %>" alt="<%= product.product_name %>" class="product-thumb" />
            <% } else { %>
              -
            <% } %>
          </td>
          <td><%= product.product_name %></td>
          <td><%= product.description || '-' %></td>
          <td>$<%= Number(product.price).toFixed(2) %></td>
          <td><%= product.stock %></td>
          <td><%= product.Category ? product.Category.category_name : '-' %></td>
          <td class="actions">
            <a href="/products/<%= product.product_id %>" class="btn btn-info">View</a>
            <% if (isAdmin) { %>
              <a href="/products/<%= product.product_id %>/edit" class="btn btn-warning">Edit</a>
              <form action="/products/<%= product.product_id %>?_method=DELETE" method="POST" class="inline-form">
                <button type="submit" class="btn btn-delete" data-confirm-delete="Delete this product?">Delete</button>
              </form>
            <% } else { %>
              <form action="/orders/quick" method="POST" class="inline-form">
                <input type="hidden" name="product_id" value="<%= product.product_id %>" />
                <input type="hidden" name="quantity" value="1" />
                <button type="submit" class="btn btn-create">Order</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<% if (totalPages > 1) { %>
  <nav class="pagination">
    <% if (hasPreviousPage) { %>
      <a href="/products?page=<%= currentPage - 1 %>&search=<%= encodeURIComponent(searchQuery) %>&category=<%= selectedCategory %>">
        Previous
      </a>
    <% } %>

    <% for (let i = 1; i <= totalPages; i++) { %>
      <a
        href="/products?page=<%= i %>&search=<%= encodeURIComponent(searchQuery) %>&category=<%= selectedCategory %>"
        class="<%= i === currentPage ? 'active' : '' %>"
      >
        <%= i %>
      </a>
    <% } %>

    <% if (hasNextPage) { %>
      <a href="/products?page=<%= currentPage + 1 %>&search=<%= encodeURIComponent(searchQuery) %>&category=<%= selectedCategory %>">
        Next
      </a>
    <% } %>
  </nav>
<% } %>
